{
  "entities": {
    "users": {
      "title": "User Profile",
      "description": "Core user information and roles",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "matricule": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "teacher", "student"] },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "mustChangePassword": { "type": "boolean" },
        "status": { "type": "string", "enum": ["online", "offline"] },
        "fcmToken": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "matricule", "email", "role", "firstName", "lastName"]
    },
    "students": {
      "title": "Student Details",
      "description": "Extended information for students",
      "type": "object",
      "properties": {
        "birthDate": { "type": "string" },
        "birthPlace": { "type": "string" },
        "gender": { "type": "string", "enum": ["M", "F"] },
        "cni": { "type": "string" },
        "phone": { "type": "string" },
        "parentName": { "type": "string" },
        "parentPhone": { "type": "string" },
        "classId": { "type": "string" }
      }
    },
    "teachers": {
      "title": "Teacher Details",
      "description": "Extended information for teachers",
      "type": "object",
      "properties": {
        "hourlyRate": { "type": "number" },
        "assignedClasses": { "type": "array", "items": { "type": "string" } },
        "phone": { "type": "string" },
        "minStudentsCondition": { "type": "number", "description": "Minimum students per class for full pay" },
        "specialConditions": { "type": "string", "description": "Specific contract notes" }
      }
    },
    "finances": {
      "title": "Unified Transaction Ledger",
      "description": "Central ledger for all financial movements",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string", "enum": ["inscription", "scolarite", "vorbereitung", "diverse", "virement_cb", "sortie"] },
        "eleve_id": { "type": "string" },
        "libelle": { "type": "string" },
        "montant": { "type": "number" },
        "date_versement": { "type": "string", "format": "date-time" },
        "mode_paiement": { "type": "string", "enum": ["Espèces", "Mobile Money", "Virement", "Autre"] },
        "compte_destination": { "type": "string", "enum": ["caisse", "banque"] },
        "compte_source": { "type": "string", "enum": ["caisse", "banque"] },
        "saisi_par": { "type": "string", "description": "User UID who recorded the transaction" },
        "niveau_id": { "type": "string" },
        "type_versement": { "type": "string", "enum": ["scolarite", "examen", "autre"] },
        "recu_numero": { "type": "string" },
        "timestamp_creation": { "type": "string", "format": "date-time" },
        "modifie": { "type": "boolean" },
        "supprime": { "type": "boolean" },
        "deletion_reason": { "type": "string" }
      }
    },
    "comptes": {
      "title": "Account Balance",
      "description": "Real-time balances for cash and bank",
      "type": "object",
      "properties": {
        "solde_actuel": { "type": "number" },
        "derniere_maj": { "type": "string", "format": "date-time" }
      }
    },
    "vorbereitung": {
      "title": "Intensive Prep Account",
      "description": "Tracks intensive preparation fees per student",
      "type": "object",
      "properties": {
        "eleve_id": { "type": "string" }
      }
    },
    "sorties": {
      "title": "Expense Record",
      "description": "Detailed tracking of all center expenditures",
      "type": "object",
      "properties": {
        "categorie": { "type": "string", "enum": ["Salaires enseignants", "Connexion Internet", "Loyer", "Eau & Électricité", "Matériel pédagogique", "Produits d'entretien", "Autre"] },
        "libelle": { "type": "string" },
        "montant": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "source_compte": { "type": "string", "enum": ["caisse", "banque"] },
        "justificatif_url": { "type": "string" },
        "enseignant_id": { "type": "string" },
        "saisi_par": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "classes": {
      "title": "Classroom",
      "description": "Class management and scheduling",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "capacity": { "type": "number" },
        "teacherId": { "type": "string" },
        "studentIds": { "type": "array", "items": { "type": "string" } },
        "schedule": { "type": "array" }
      }
    },
    "library": {
      "title": "Library Item",
      "description": "Educational documents and resources",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "downloadUrl": { "type": "string" },
        "category": { "type": "string" },
        "addedAt": { "type": "string" }
      }
    },
    "communiques": {
      "title": "Communique",
      "description": "Administrative announcements and news",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "targetRoles": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" },
        "isArchived": { "type": "boolean" }
      },
      "required": ["title", "content", "authorId", "targetRoles", "createdAt"]
    },
    "communiqueRead": {
      "title": "Communique Read Record",
      "description": "Timestamp and user info of when a communique was read",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "readAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "readAt"]
    },
    "ecole": {
      "title": "School Config",
      "description": "Global settings for the establishment",
      "type": "object",
      "properties": {
        "nom": { "type": "string" },
        "logo_url": { "type": "string" },
        "annee_scolaire": { "type": "string" },
        "format_recu": { "type": "string", "enum": ["A5", "thermique_58", "thermique_80"] }
      }
    },
    "rapports_journaliers": {
      "title": "Daily Report",
      "description": "Daily teaching activity reports",
      "type": "object",
      "properties": {
        "enseignant_id": { "type": "string" },
        "enseignant_nom": { "type": "string" },
        "classe_id": { "type": "string" },
        "matiere": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "contenu": { "type": "string" },
        "presents": { "type": "integer" },
        "absents": { "type": "integer" },
        "observations": { "type": "string" },
        "devoirs": { "type": "string" },
        "statut": { "type": "string", "enum": ["brouillon", "soumis"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["enseignant_id", "classe_id", "date", "contenu", "statut"]
    },
    "chat_eleves": {
      "title": "Student Chat Message",
      "description": "Anonymized chat for students",
      "type": "object",
      "properties": {
        "uid_auteur": { "type": "string" },
        "nom_auteur": { "type": "string" },
        "alias": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "supprime": { "type": "boolean" },
        "reponse_admin": { "type": "string" }
      },
      "required": ["uid_auteur", "message", "timestamp"]
    },
    "scolarites": {
      "title": "Tuition Account",
      "description": "Master tuition balance for a student at a specific level",
      "type": "object",
      "properties": {
        "eleve_id": { "type": "string" },
        "matricule": { "type": "string" },
        "nom_eleve": { "type": "string" },
        "levelId": { "type": "string" },
        "montant_total_du": { "type": "number" },
        "total_verse": { "type": "number" },
        "reste": { "type": "number" },
        "surplus": { "type": "boolean" },
        "statut_paiement": { "type": "string", "enum": ["EN COURS", "SOLDÉ", "SURPLUS", "NON PAYÉ"] }
      },
      "required": ["eleve_id", "matricule", "montant_total_du"]
    },
    "versement": {
      "title": "Versements Item",
      "description": "Individual payment transaction",
      "type": "object",
      "properties": {
        "montant": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "mode_paiement": { "type": "string", "enum": ["Espèces", "Mobile Money", "Virement", "Autre"] },
        "recu_numero": { "type": "string" },
        "caissier_id": { "type": "string" },
        "notes": { "type": "string" },
        "recu_genere_at": { "type": "string", "format": "date-time" },
        "recu_genere_par": { "type": "string" }
      },
      "required": ["montant", "date", "mode_paiement"]
    },
    "audit_logs": {
      "title": "Audit Logs",
      "description": "System-wide activity log",
      "type": "object",
      "properties": {
        "action": { "type": "string" },
        "user_id": { "type": "string" },
        "cible_id": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "details": { "type": "object" }
      },
      "required": ["action", "user_id", "timestamp"]
    },
    "cours_vacances": {
      "title": "Summer Course Session",
      "description": "Definition of a summer course session",
      "type": "object",
      "properties": {
        "titre": { "type": "string" },
        "dateDescription": { "type": "string" },
        "prix": { "type": "number" },
        "cycle": { "type": "string", "enum": ["Allemand", "Anglais"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      }
    },
    "vacances_inscription": {
      "title": "Summer Course Enrollment",
      "description": "Student enrollment in a summer session",
      "type": "object",
      "properties": {
        "eleve_id": { "type": "string" },
        "nom": { "type": "string" },
        "prenom": { "type": "string" },
        "matricule": { "type": "string" },
        "montant_total_du": { "type": "number" },
        "total_verse": { "type": "number" },
        "reste": { "type": "number" },
        "statut": { "type": "string" }
      }
    },
    "transactions": {
      "title": "Financial Transaction",
      "description": "Individual financial record in the ledger",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "amount": { "type": "number" },
        "date": { "type": "string" },
        "description": { "type": "string" }
      }
    }
  },
  "firestore": {
    "/ecole/{configId}": {
      "schema": "ecole",
      "description": "Global school config"
    },
    "/rapports_journaliers/{rapportId}": {
      "schema": "rapports_journaliers",
      "description": "Teacher reports"
    },
    "/chat_eleves/{messageId}": {
      "schema": "chat_eleves",
      "description": "Student chat messages"
    },
    "/scolarites/{eleveId}": {
      "schema": "scolarites",
      "description": "Tuition accounts"
    },
    "/scolarites/{eleveId}/versements/{versementId}": {
      "schema": "versement",
      "description": "Individual payments"
    },
    "/comptes/{accountId}": {
      "schema": "comptes",
      "description": "Cash and Bank account balances"
    },
    "/vorbereitung/{eleveId}": {
      "schema": "vorbereitung",
      "description": "Intensive preparation tracking"
    },
    "/vorbereitung/{eleveId}/versements/{versementId}": {
      "schema": "versement",
      "description": "Payments for intensive prep"
    },
    "/cours_vacances/{sessionId}": {
      "schema": "cours_vacances",
      "description": "Summer course sessions"
    },
    "/cours_vacances/{sessionId}/inscriptions/{studentId}": {
      "schema": "vacances_inscription",
      "description": "Summer course enrollments"
    },
    "/cours_vacances/{sessionId}/inscriptions/{studentId}/versements/{versementId}": {
      "schema": "versement",
      "description": "Summer course payments"
    },
    "/sorties/{sortieId}": {
      "schema": "sorties",
      "description": "Expense details"
    },
    "/audit_logs/{logId}": {
      "schema": "audit_logs",
      "description": "Audit trail"
    },
    "/users/{userId}": {
      "schema": "users",
      "description": "User profiles"
    },
    "/students/{studentId}": {
      "schema": "students",
      "description": "Student specific data"
    },
    "/teachers/{teacherId}": {
      "schema": "teachers",
      "description": "Teacher specific data"
    },
    "/finances/{recordId}": {
      "schema": "finances",
      "description": "Financial records"
    },
    "/transactions/{transId}": {
      "schema": "transactions",
      "description": "Detailed ledger transactions"
    },
    "/classes/{classId}": {
      "schema": "classes",
      "description": "Class information"
    },
    "/library/{itemId}": {
      "schema": "library",
      "description": "Library resources"
    },
    "/communiques/{communiqueId}": {
      "schema": "communiques",
      "description": "Announcements"
    },
    "/communiques/{communiqueId}/reads/{userId}": {
      "schema": "communiqueRead",
      "description": "Tracking who read the communique"
    }
  }
}
