// ===============================================================
// Assumed Data Model
// ===============================================================
//
// Collection: users
// Fields:
//   - uid: string (required)
//   - matricule: string (required)
//   - email: string (required, email format)
//   - role: string (required, ['admin', 'teacher', 'student'])
//   - firstName: string (required)
//   - lastName: string (required)
//   - mustChangePassword: bool (optional)
//   - status: string (required, ['online', 'offline'])
//   - createdAt: string (required, ISO 8601)
//
// Collection: students
// Fields:
//   - birthDate: string
//   - birthPlace: string
//   - gender: string (['M', 'F'])
//   - phone: string
//   - parentName: string
//   - parentPhone: string
//   - classId: string
//
// Collection: teachers
// Fields:
//   - hourlyRate: number
//   - assignedClasses: list
//   - phone: string
//
// Collection: finances
// Fields:
//   - type: string (['income', 'expense'])
//   - amount: number
//   - date: string
//   - description: string
//   - bankBalanceAfter: number
//   - cashBalanceAfter: number
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net - Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // Shared Helpers
    // ===============================================================

    function isSignedIn() {
      return request.auth != null;
    }

    // Identifies if the user is a verified admin or a bootstrap admin
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == "yombivictor@gmail.com" ||
        request.auth.token.email == "gabrielyombi311@gmail.com" || 
        request.auth.uid == "ODbaguDQ7GRMDmGLo8SzsH46u2E2" || // Reported User UID
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isVerified() {
      // Mandate verification for write operations as per instructions, 
      // but allow bootstrap admins even if unverified for initial setup.
      return isSignedIn() && (
        request.auth.token.email_verified == true ||
        request.auth.token.email == "yombivictor@gmail.com" ||
        request.auth.token.email == "gabrielyombi311@gmail.com" ||
        request.auth.uid == "ODbaguDQ7GRMDmGLo8SzsH46u2E2"
      );
    }

    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }

    function incoming() { 
      return request.resource.data; 
    }

    function existing() { 
      return resource.data; 
    }

    // ===============================================================
    // Entity Validators
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'matricule', 'email', 'role', 'firstName', 'lastName', 'status', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.role in ['admin', 'teacher', 'student'] &&
             data.email is string &&
             data.firstName is string && data.firstName.size() < 100 &&
             data.lastName is string && data.lastName.size() < 100;
    }

    function isValidChatMessage(data) {
      return data.keys().hasAll(['uid_auteur', 'alias', 'message', 'timestamp', 'supprime']) &&
             data.uid_auteur == request.auth.uid &&
             data.message is string && data.message.size() > 0 && data.message.size() <= 2000 &&
             data.alias is string &&
             data.supprime is bool;
    }

    function isValidFinance(data) {
      return data.keys().hasAll(['type', 'amount', 'date', 'description']) &&
             data.type in ['income', 'expense'] &&
             data.amount is number && data.amount >= 0;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Chat Éleves - Public chat area
    match /chat_eleves/{messageId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isVerified() && isValidChatMessage(incoming());
      
      allow update: if isVerified() && (
        isAdmin() || 
        (existing().uid_auteur == request.auth.uid && incoming().diff(existing()).affectedKeys().hasOnly(['supprime']))
      );
      
      allow delete: if isAdmin();
    }

    // Users & Profiles
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin() || resource.data.matricule in ['T26001', 'S26001']);
      allow create: if isSignedIn() && isValidUser(incoming()) && (isOwner(userId) || isAdmin());
      allow update: if isVerified() && (
        isAdmin() || 
        (isOwner(userId) && incoming().role == existing().role && incoming().uid == existing().uid)
      );
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isSignedIn() && (isOwner(studentId) || isAdmin());
      allow write: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow read: if isSignedIn() && (isOwner(teacherId) || isAdmin());
      allow write: if isAdmin();
    }

    // Academy Data
    match /ecole/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Finance & Scolarite
    match /finances/{recordId} {
      allow read: if isAdmin();
      allow write: if isAdmin() && isValidFinance(incoming());
    }

    match /scolarites/{eleveId} {
      allow read: if isAdmin() || isOwner(eleveId);
      allow write: if isAdmin();

      match /versements/{versementId} {
        allow read: if isAdmin() || isOwner(eleveId);
        allow create: if isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    // Reports & Communiques
    match /rapports_journaliers/{rapportId} {
      allow read: if isAdmin() || (isSignedIn() && existing().enseignant_id == request.auth.uid);
      allow create: if isSignedIn() && incoming().enseignant_id == request.auth.uid;
      allow update: if isAdmin() || (isSignedIn() && existing().enseignant_id == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /communiques/{communiqueId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
      
      match /reads/{userId} {
        allow read: if isAdmin() || isOwner(userId);
        allow create: if isOwner(userId);
      }
    }

    match /audit_log/{logId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /library/{itemId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
