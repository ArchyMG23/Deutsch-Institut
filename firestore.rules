rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if isAuth() && request.auth.token.email in ['yombivictor@gmail.com', 'gabrielyombi311@gmail.com'];
    }

    function isAuth()       { return request.auth != null; }
    
    function isAdmin()      {
      return isAuth() && (
        request.auth.token.email in ['yombivictor@gmail.com', 'gabrielyombi311@gmail.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'])
      );
    }
    
    function isSuperAdmin() {
      return isAuth() && (
        request.auth.token.email in ['yombivictor@gmail.com', 'gabrielyombi311@gmail.com'] ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin')
      );
    }
    
    function isOwner(uid)   {
      return isAuth() && request.auth.uid == uid;
    }

    // Comptes financiers — lecture admin, écriture engine via isAdmin()
    match /comptes/{compte} {
      allow read:  if isAdmin();
      allow write: if isAdmin(); 
    }

    // Transactions
    match /transactions/{id} {
      allow read:   if isAdmin();
      allow create: if isAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }
    
    // Finances (Flattened records)
    match /finances/{id} {
      allow read:   if isAdmin();
      allow create: if isAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }
    
    // Sorties
    match /sorties/{id} {
      allow read:   if isAdmin();
      allow create: if isAdmin();
      allow update: if isSuperAdmin();
      allow delete: if isSuperAdmin();
    }

    // Scolarités
    match /scolarites/{eleve_id} {
      allow read:  if isAdmin() || isOwner(eleve_id);
      allow write: if isAdmin();
      match /versements/{vid} {
        allow read:  if isAdmin() || isOwner(eleve_id);
        allow write: if isAdmin();
      }
    }

    // Vorbereitung
    match /vorbereitung/{eleve_id} {
      allow read:  if isAdmin() || isOwner(eleve_id);
      allow write: if isAdmin();
      match /versements/{vid} {
        allow read:  if isAdmin() || isOwner(eleve_id);
        allow write: if isAdmin();
      }
    }

    // Cours de vacances
    match /cours_vacances/{session_id} {
      allow read:  if isAuth();
      allow write: if isAdmin();
      match /inscriptions/{eleve_id} {
        allow read:  if isAdmin() || isOwner(eleve_id);
        allow write: if isAdmin();
        match /versements/{vid} {
          allow read:  if isAdmin() || isOwner(eleve_id);
          allow write: if isAdmin();
        }
      }
    }

    // Élèves
    match /eleves/{eleve_id} {
      allow read:  if isAdmin() || isOwner(eleve_id);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }
    
    // Support for students collection as well
    match /students/{eleve_id} {
      allow read:  if isAdmin() || isOwner(eleve_id);
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isSuperAdmin();
    }

    // Users
    match /users/{uid} {
       allow read: if isAdmin() || isOwner(uid);
       allow create: if isAdmin() || isOwner(uid);
       allow update: if isAdmin() || isOwner(uid);
       allow delete: if isSuperAdmin();
    }

    // Enseignants, séances, rapports
    match /enseignants/{id} {
      allow read, write: if isAdmin();
    }
    match /teachers/{id} {
      allow read, write: if isAdmin();
    }
    match /seances/{id} {
      allow read:   if isAdmin() || 
        (resource != null && resource.data.enseignant_id == request.auth.uid);
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }
    match /rapports_journaliers/{id} {
      allow read:   if isAdmin() || 
        (resource != null && resource.data.enseignant_id == request.auth.uid);
      allow create: if isAuth();
      allow update: if isAdmin() || 
        (resource != null && resource.data.enseignant_id == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Chat élèves (anonymat garanti)
    match /chat_eleves/{id} {
      allow read:   if isAuth();
      allow create: if isAuth();
      allow delete: if isAdmin() || 
        (resource != null && resource.data.uid_auteur == request.auth.uid);
    }
    
    // Classes, Levels
    match /classes/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
    match /levels/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Evaluations
    match /evaluations/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    // Logs — lecture seule super admin
    match /audit_log/{id}    { allow read: if isSuperAdmin(); }
    match /error_log/{id}    { 
      allow read: if isSuperAdmin(); 
      allow create: if isAuth();
    }
    match /maintenance_log/{id} { allow read: if isSuperAdmin(); }
    
    // Legacy support for audit_logs (plural)
    match /audit_logs/{id}    { allow read: if isSuperAdmin(); }
    
    // Library
    match /library/{id} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }
  }
}
